# GeonicDB forwarding config for co2-logger.
#
# Copy this to the machine (NOT into git) and point the systemd unit at it via
#   EnvironmentFile=-/home/<user>/.secrets/geonicdb-co2.env
# Then `chmod 600` it. Leaving GEONICDB_URL / GEONICDB_API_KEY unset simply
# disables forwarding — the logger still serves sensor.json locally.

GEONICDB_URL=https://broker.example
GEONICDB_API_KEY=replace-with-your-api-key
GEONICDB_TENANT=your-tenant
GEONICDB_SERVICEPATH=/devices/co2
GEONICDB_ENTITY_ID=urn:ngsi-ld:AirQualityObserved:co2-sensor-01
GEONICDB_INTERVAL=60
